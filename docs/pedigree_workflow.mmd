%%{init: {'theme': 'base', 'themeVariables': {'primaryColor': '#4a90d9', 'primaryTextColor': '#fff', 'primaryBorderColor': '#2c6fbb', 'lineColor': '#555', 'secondaryColor': '#f0f4fa', 'tertiaryColor': '#e8f5e9', 'fontSize': '14px'}, 'flowchart': {'defaultRenderer': 'elk'}}}%%

flowchart TD
    %% ── Inputs ──
    subgraph INPUTS["<b>Inputs</b>"]
        direction LR
        bam["HiFi BAMs"]
        ss_vcf["Single-Sample VCFs<br/><i>(DeepVariant, pbsv)</i>"]
        joint_vcf["Joint-Called<br/>Multi-Sample VCF"]
        ref["Reference Genome<br/><i>(GRCh38)</i>"]
        ped["Pedigree File<br/><i>(.ped)</i>"]
    end

    %% ── Step 1A: Read-Backed Phasing ──
    subgraph S1["<b>Step 1A: Read-Backed Phasing</b>"]
        s1_tool["<b>hiphase</b> v1.5+"]
        s1_desc["Phase VCF variants using<br/>read overlap across sites,<br/>then haplotag BAMs"]
        s1_out1["Phased VCFs<br/><i>(hap1|hap2)</i>"]
        s1_out2["Haplotagged BAMs<br/><i>(HP/PS tags)</i>"]
        s1_out3["Phase Blocks<br/><i>(.blocks.tsv)</i>"]
        s1_tool --- s1_desc
        s1_desc --> s1_out1 & s1_out2 & s1_out3
    end

    %% ── Step 1B: Inheritance-Based Phasing ──
    subgraph S1B["<b>Step 1B: Inheritance-Based Phasing</b>"]
        s1b_tool["<b>gtg-ped-map</b> +<br/><b>gtg-concordance</b>"]
        s1b_desc["Map haplotypes to founders<br/>using pedigree inheritance"]
        s1b_out1["Inheritance-Phased VCF<br/><i>(pat|mat)</i>"]
        s1b_out2["Inheritance Blocks<br/><i>(.iht.sorted.txt)</i>"]
        s1b_tool --- s1b_desc
        s1b_desc --> s1b_out1 & s1b_out2
    end

    %% ── Step 2: CpG Methylation ──
    subgraph S2["<b>Step 2: Compute CpG Methylation</b>"]
        s2_tool["<b>pb-CpG-tools</b> v3.0+<br/><i>(aligned_bam_to_cpg_scores)</i>"]
        s2_desc["Extract per-CpG methylation<br/>from haplotagged reads"]
        s2_out1["Hap1 Methylation<br/><i>(.hap1.bed.gz)</i>"]
        s2_out2["Hap2 Methylation<br/><i>(.hap2.bed.gz)</i>"]
        s2_out3["Combined Methylation<br/><i>(.combined.bed.gz)</i>"]
        s2_note["Count-based + Model-based<br/>min-coverage=10, min-mapq=1"]
        s2_tool --- s2_desc
        s2_desc --> s2_out1 & s2_out2 & s2_out3
        s2_desc -.- s2_note
    end

    %% ── Step 3: Phase Methylation to Founders ──
    subgraph S3["<b>Step 3: Phase Methylation to Founder Haplotypes</b>"]
        s3_tool["<b>phase_meth_to_founder_haps.py</b>"]
        s3_p1["Merge read-backed +<br/>inheritance-based phasing of SNVs"]
        s3_p2["Build haplotype map<br/><i>(bit-vector concordance)</i>"]
        s3_p3["Assign CpG methylation<br/>to founder haplotypes"]
        s3_out1["Founder-Phased<br/>Methylation BED"]
        s3_out2["Mismatch Sites<br/><i>(phasing disagreements)</i>"]
        s3_out3["BigWig Tracks<br/><i>(pat/mat x count/model)</i>"]
        s3_tool --> s3_p1 --> s3_p2 --> s3_p3
        s3_p3 --> s3_out1 & s3_out2 & s3_out3
    end

    %% ── Step 4: Expand to All CpGs ──
    subgraph S4["<b>Step 4: Expand to All CpG Sites</b>"]
        s4a_tool["<b>write_all_cpgs_in_reference.py</b>"]
        s4a_desc["Enumerate all CpG sites<br/>in reference genome"]
        s4b_tool["<b>expand_to_all_cpgs.py</b>"]
        s4b_p1["Join reference CpGs with<br/>unphased + phased methylation"]
        s4b_p2["Flag allele-specific CpGs<br/><i>(created/destroyed by SNVs)</i>"]
        s4b_p3["Compute QC of phased methylation<br/><i>(coverage, mismatch proximity)</i>"]
        s4_out["Comprehensive All-CpG<br/>Methylation Dataset<br/><i>(.all_cpgs.bed)</i>"]
        s4a_tool --> s4a_desc --> s4b_tool
        s4b_tool --> s4b_p1 --> s4b_p2 --> s4b_p3 --> s4_out
    end

    %% ── Connections ──
    bam --> S1
    ss_vcf --> S1
    joint_vcf --> S1B
    ped --> S1B
    ref --> S1 & S1B & S2 & S4

    s1_out1 --> S3
    s1_out2 --> S2
    s1_out3 --> S3
    s1b_out1 --> S3
    s1b_out2 --> S3

    s2_out1 --> S3
    s2_out2 --> S3
    s2_out3 --> S4

    s3_out1 --> S4
    s3_out2 --> S4

    joint_vcf --> S4

    %% ── Styles ──
    classDef inputStyle fill:#fff3e0,stroke:#e65100,color:#333
    classDef step1Style fill:#e3f2fd,stroke:#1565c0,color:#333
    classDef step1bStyle fill:#ede7f6,stroke:#4527a0,color:#333
    classDef step2Style fill:#e8f5e9,stroke:#2e7d32,color:#333
    classDef step3Style fill:#fce4ec,stroke:#c62828,color:#333
    classDef step4Style fill:#fff8e1,stroke:#f9a825,color:#333

    class INPUTS inputStyle
    class S1 step1Style
    class S1B step1bStyle
    class S2 step2Style
    class S3 step3Style
    class S4 step4Style
